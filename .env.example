# ============================================================
# OSINT Dashboard — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ---- General ----
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ---- PostgreSQL ----
DATABASE_URL=postgres://osint:osint_secret@postgres:5432/osint_db

# ---- Redis ----
REDIS_URL=redis://redis:6379

# ---- Elasticsearch ----
ELASTICSEARCH_URL=http://elasticsearch:9200

# ---- Neo4j ----
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=osint_secret

# ---- MinIO (S3-compatible object storage) ----
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=osint-files
MINIO_USE_SSL=false

# ---- Authentication / JWT ----
JWT_SECRET=CHANGE_ME_random_64_char_string
JWT_REFRESH_SECRET=CHANGE_ME_another_random_64_char_string
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ---- Encryption (for stored API keys) ----
ENCRYPTION_KEY=CHANGE_ME_32_byte_hex_key

# ---- OSINT / Intelligence API Keys ----
SHODAN_API_KEY=
VIRUSTOTAL_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
HUNTER_API_KEY=
HAVE_I_BEEN_PWNED_API_KEY=
GREYNOISE_API_KEY=
ALIENVAULT_OTX_API_KEY=
URLSCAN_API_KEY=
WHOISXML_API_KEY=
SECURITYTRAILS_API_KEY=
IPINFO_TOKEN=
ABUSEIPDB_API_KEY=
PASSIVETOTAL_USERNAME=
PASSIVETOTAL_API_KEY=
CIRCL_USERNAME=
CIRCL_PASSWORD=
MALTEGO_API_KEY=
SPIDERFOOT_API_KEY=
BINARYEDGE_API_KEY=
ZOOMEYE_API_KEY=
FULLCONTACT_API_KEY=
CLEARBIT_API_KEY=
BUILTWITH_API_KEY=

# ---- OAuth2 / SSO ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_CALLBACK_URL=http://localhost:4000/auth/azure/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/auth/github/callback

# ---- Logging ----
LOG_LEVEL=info

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ---- Worker Concurrency ----
COLLECTION_CONCURRENCY=5
ENRICHMENT_CONCURRENCY=3
DEDUP_CONCURRENCY=2
ALERT_CONCURRENCY=2

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000
