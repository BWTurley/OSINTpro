{
  "index_patterns": ["threat-indicators*"],
  "priority": 100,
  "template": {
    "settings": {
      "number_of_shards": 2,
      "number_of_replicas": 1,
      "analysis": {
        "analyzer": {
          "ioc_analyzer": {
            "type": "custom",
            "tokenizer": "uax_url_email",
            "filter": ["lowercase"]
          }
        }
      }
    },
    "mappings": {
      "dynamic": "strict",
      "properties": {
        "id": { "type": "keyword" },
        "type": { "type": "keyword" },
        "indicator_type": { "type": "keyword" },
        "value": {
          "type": "text",
          "analyzer": "ioc_analyzer",
          "fields": { "keyword": { "type": "keyword" } }
        },
        "threat_type": { "type": "keyword" },
        "malware_family": { "type": "keyword" },
        "severity": { "type": "keyword" },
        "confidence": { "type": "float" },
        "risk_score": { "type": "float" },
        "tlp": { "type": "keyword" },
        "tags": { "type": "keyword" },
        "source": { "type": "keyword" },
        "source_feed": { "type": "keyword" },
        "source_url": { "type": "keyword" },
        "description": { "type": "text" },
        "context": {
          "type": "nested",
          "properties": {
            "key": { "type": "keyword" },
            "value": { "type": "text", "fields": { "keyword": { "type": "keyword" } } }
          }
        },
        "related_indicators": { "type": "keyword" },
        "related_entities": { "type": "keyword" },
        "kill_chain_phase": { "type": "keyword" },
        "attack_pattern": { "type": "keyword" },
        "mitre_attack_id": { "type": "keyword" },
        "geo_location": { "type": "geo_point" },
        "country_code": { "type": "keyword" },
        "asn": { "type": "keyword" },
        "as_org": { "type": "text", "fields": { "keyword": { "type": "keyword" } } },
        "whois_registrant": { "type": "text" },
        "first_seen": { "type": "date" },
        "last_seen": { "type": "date" },
        "expiration_date": { "type": "date" },
        "created_at": { "type": "date" },
        "updated_at": { "type": "date" },
        "created_by": { "type": "keyword" },
        "investigation_id": { "type": "keyword" },
        "is_active": { "type": "boolean" },
        "is_false_positive": { "type": "boolean" }
      }
    }
  }
}
